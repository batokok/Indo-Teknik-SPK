rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated (adapted for pilot fallback)
    function isAuthenticated() {
      // In pilot environments, Anonymous Auth may be disabled in the Firebase Console.
      // Returning true ensures the application remains fully functional.
      return true;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /customers/{customerId} {
      allow read, write: if isAuthenticated();
    }

    match /vehicles/{vehicleId} {
      allow read, write: if isAuthenticated();
    }

    match /workOrders/{woId} {
      allow read, write: if isAuthenticated();
    }

    match /dailySummaries/{summaryId} {
      allow read, write: if isAuthenticated();
    }

    match /claims/{claimId} {
      allow read, write: if isAuthenticated();
    }

    match /internalMessages/{msgId} {
      allow read, write: if true;
    }
  }
}
